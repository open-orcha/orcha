{
  "$description": "Orcha mobile design tokens — single source for the iOS and Android apps. Values are mapped 1:1 from the web portal CSS variables (orcha-cli/orcha_cli/templates/portal/static/styles.css) so all three clients share one visual language. Consumers: Android maps these to a Material 3 ColorScheme + Compose theme; iOS maps them to asset-catalog colors + a SwiftUI theme struct. Do not fork values per platform — change here, propagate to both.",
  "$version": "1.0.0",

  "color": {
    "dark": {
      "bg":          "#0a0d12",
      "bgGrad1":     "rgba(21, 192, 198, 0.055)",
      "bgGrad2":     "rgba(125, 145, 255, 0.045)",
      "surface":     "#111620",
      "surface2":    "#161d29",
      "surface3":    "#1c2532",
      "raised":      "#1a2230",
      "border":      "#232d3d",
      "border2":     "#2c3848",
      "hover":       "#1a2230",
      "text":        "#e8edf6",
      "text2":       "#c4cedd",
      "muted":       "#8b98ae",
      "faint":       "#5a6678",
      "accent":      "#1fc7cd",
      "accentInk":   "#04181a",
      "accentSoft":  "rgba(31, 199, 205, 0.12)",
      "accentLine":  "rgba(31, 199, 205, 0.34)",
      "accentGlow":  "rgba(31, 199, 205, 0.22)",
      "amber":       "#f2a83c",
      "ok":          "#38d39a",
      "okSoft":      "rgba(56, 211, 154, 0.12)",
      "okLine":      "rgba(56, 211, 154, 0.32)",
      "info":        "#5aa6ff",
      "infoSoft":    "rgba(90, 166, 255, 0.12)",
      "infoLine":    "rgba(90, 166, 255, 0.32)",
      "warn":        "#f5b13d",
      "warnSoft":    "rgba(245, 177, 61, 0.13)",
      "warnLine":    "rgba(245, 177, 61, 0.34)",
      "danger":      "#f6757e",
      "dangerSoft":  "rgba(246, 117, 126, 0.12)",
      "dangerLine":  "rgba(246, 117, 126, 0.32)",
      "violet":      "#b08cff",
      "violetSoft":  "rgba(176, 140, 255, 0.13)",
      "violetLine":  "rgba(176, 140, 255, 0.32)",
      "idle":        "#6b788e",
      "idleSoft":    "rgba(107, 120, 142, 0.14)",
      "idleLine":    "rgba(107, 120, 142, 0.30)",
      "diffAdd":     "#8fe3a8",
      "diffAddBg":   "rgba(56, 211, 154, 0.10)",
      "diffDel":     "#f6909a",
      "diffDelBg":   "rgba(246, 117, 126, 0.10)",
      "diffHunk":    "#5aa6ff",
      "diffHunkBg":  "rgba(90, 166, 255, 0.07)"
    },
    "light": {
      "bg":          "#f3f6fa",
      "bgGrad1":     "rgba(21, 192, 198, 0.07)",
      "bgGrad2":     "rgba(125, 145, 255, 0.06)",
      "surface":     "#ffffff",
      "surface2":    "#f5f8fc",
      "surface3":    "#eef3f9",
      "raised":      "#ffffff",
      "border":      "#e4eaf2",
      "border2":     "#d3dce8",
      "hover":       "#f1f5fa",
      "text":        "#0e1722",
      "text2":       "#2c3a4d",
      "muted":       "#5a6678",
      "faint":       "#8794a6",
      "accent":      "#0c9aa0",
      "accentInk":   "#ffffff",
      "accentSoft":  "rgba(12, 154, 160, 0.10)",
      "accentLine":  "rgba(12, 154, 160, 0.30)",
      "accentGlow":  "rgba(12, 154, 160, 0.18)",
      "amber":       "#d9881c",
      "ok":          "#11a472",
      "okSoft":      "rgba(17, 164, 114, 0.11)",
      "okLine":      "rgba(17, 164, 114, 0.28)",
      "info":        "#2f74e6",
      "infoSoft":    "rgba(47, 116, 230, 0.10)",
      "infoLine":    "rgba(47, 116, 230, 0.26)",
      "warn":        "#c9871a",
      "warnSoft":    "rgba(201, 135, 26, 0.13)",
      "warnLine":    "rgba(201, 135, 26, 0.30)",
      "danger":      "#d94a55",
      "dangerSoft":  "rgba(217, 74, 85, 0.10)",
      "dangerLine":  "rgba(217, 74, 85, 0.26)",
      "violet":      "#7b54d6",
      "violetSoft":  "rgba(123, 84, 214, 0.11)",
      "violetLine":  "rgba(123, 84, 214, 0.26)",
      "idle":        "#768296",
      "idleSoft":    "rgba(118, 130, 150, 0.13)",
