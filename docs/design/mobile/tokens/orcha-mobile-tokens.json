      "diffHunk":    "#2f74e6",
      "diffHunkBg":  "rgba(47, 116, 230, 0.08)"
    },
    "brand": {
      "iconTileGradientInner": "#0e2d33",
      "iconTileGradientOuter": "#06171c",
      "orcaBody":              "#f3fbfb",
      "orcaAccent":            "#1fc7cd"
    }
  },

  "statusColor": {
    "$description": "Which semantic color each domain status maps to. Same mapping as the portal pill classes (s-working/s-ok/s-info/s-warn/s-bad/s-acc/s-idle). Badge = <color> text on <color>Soft background with <color>Line border.",
    "task": {
      "pending":            "idle",
      "ready":              "info",
      "in_progress":        "accent",
      "blocked":            "warn",
      "needs_verification": "violet",
      "completed":          "ok",
      "cancelled":          "danger"
    },
    "request": {
      "open":               "info",
      "accepted":           "accent",
      "rejected":           "danger",
      "answered":           "violet",
      "converted_to_task":  "violet",
      "closed":             "idle"
    },
    "agent": {
      "idle":            "idle",
      "working":         "accent",
      "blocked":         "warn",
      "awaiting_request":"info",
      "awaiting_human":  "violet",
      "terminated":      "danger"
    }
  },

  "typography": {
    "$description": "Portal uses Inter 400-800 + JetBrains Mono 400-700. Mobile default: platform system stacks that match Inter's metrics (SF Pro on iOS, Roboto/system on Android) with Inter as an optional bundled brand font; JetBrains Mono bundled on both for logs/ids/code.",
    "family": {
      "sans":      "Inter",
      "sansIOSFallback":     "SF Pro Text / system",
      "sansAndroidFallback": "Roboto / system",
      "mono":      "JetBrains Mono",
      "monoIOSFallback":     "SF Mono / ui-monospace",
      "monoAndroidFallback": "Roboto Mono / monospace"
    },
    "scale": {
      "displaySm":  { "size": 24, "lineHeight": 30, "weight": 800, "tracking": -0.4 },
      "titleLg":    { "size": 20, "lineHeight": 26, "weight": 750, "tracking": -0.3 },
      "titleMd":    { "size": 17, "lineHeight": 23, "weight": 700, "tracking": -0.2 },
      "titleSm":    { "size": 15, "lineHeight": 21, "weight": 650, "tracking": 0 },
      "body":       { "size": 15, "lineHeight": 22, "weight": 400, "tracking": 0 },
      "bodySm":     { "size": 13, "lineHeight": 19, "weight": 400, "tracking": 0 },
      "label":      { "size": 12, "lineHeight": 16, "weight": 650, "tracking": 0.2 },
      "overline":   { "size": 11, "lineHeight": 14, "weight": 700, "tracking": 0.8, "transform": "uppercase" },
      "mono":       { "size": 12, "lineHeight": 18, "weight": 400, "family": "mono" },
      "monoSm":     { "size": 10.5, "lineHeight": 15, "weight": 400, "family": "mono" }
    }
  },

  "spacing": {
    "$description": "4pt base grid, same rhythm as portal (portal uses 4/8/12/16/20/24).",
    "xxs": 4, "xs": 8, "sm": 12, "md": 16, "lg": 20, "xl": 24, "xxl": 32,
    "screenMarginCompact": 16,
    "listItemGap": 10,
    "cardPadding": 14
  },

  "radius": {
    "$description": "Portal radii: 12px cards, 8-9px inner elements, 999px pills. Mobile keeps the same family.",
    "sm": 8, "md": 12, "lg": 16, "xl": 22, "pill": 999,
    "sheetTop": 22,
    "bubble": 16,
    "bubbleTail": 6
  },

  "elevation": {
    "$description": "Portal shadows, adapted. On Android prefer tonal elevation (surface/surface2/surface3) over shadows in dark theme, per Material 3.",
    "level0": "none",
    "level1": { "dark": "0 1px 2px rgba(0,0,0,0.30)",   "light": "0 1px 2px rgba(16,28,48,0.06)" },
    "level2": { "dark": "0 8px 28px rgba(0,0,0,0.40)",  "light": "0 10px 30px rgba(16,28,48,0.10)" },
    "level3": { "dark": "0 24px 60px rgba(0,0,0,0.55)", "light": "0 24px 60px rgba(16,28,48,0.16)" },
    "focusRing": "0 0 0 3px {color.accentGlow}"
  },

  "motion": {
    "sheetIn":   { "duration": 280, "easing": "emphasizedDecelerate (M3) / spring(response 0.4) (iOS)" },
    "listItem":  { "duration": 180, "easing": "standard" },
    "statusPulse": { "duration": 2000, "easing": "ease-in-out", "note": "working-state glyph pulse, mirrors portal .pill.s-working animation" }
  },

  "platformMapping": {
    "materialColorScheme": {
      "$description": "How token colors fill a Material 3 ColorScheme (dark shown; light analogous).",
      "primary": "{color.dark.accent}",
      "onPrimary": "{color.dark.accentInk}",
      "primaryContainer": "{color.dark.accentSoft}",
      "onPrimaryContainer": "{color.dark.accent}",
      "secondary": "{color.dark.info}",
      "error": "{color.dark.danger}",
      "background": "{color.dark.bg}",
      "surface": "{color.dark.surface}",
      "surfaceContainer": "{color.dark.surface2}",
      "surfaceContainerHigh": "{color.dark.surface3}",
      "outline": "{color.dark.border2}",
      "outlineVariant": "{color.dark.border}",
      "onSurface": "{color.dark.text}",
      "onSurfaceVariant": "{color.dark.muted}"
    },
    "swiftUI": {
      "$description": "Asset-catalog color set names (Any/Dark appearance pairs from color.light / color.dark).",
      "names": ["OrchaBg", "OrchaSurface", "OrchaSurface2", "OrchaSurface3", "OrchaRaised", "OrchaBorder", "OrchaBorder2", "OrchaText", "OrchaText2", "OrchaMuted", "OrchaFaint", "OrchaAccent", "OrchaAccentInk", "OrchaOk", "OrchaInfo", "OrchaWarn", "OrchaDanger", "OrchaViolet", "OrchaIdle"]
    }
  }
}
