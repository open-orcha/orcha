# Generated by `orcha init` for project: {{ project_name }}
# Edit by hand only if you know what you're doing; `orcha upgrade` will overwrite.
name: orcha-{{ project_name }}

services:
  db:
    image: postgres:16
    environment:
      POSTGRES_USER: orcha
      POSTGRES_PASSWORD: orcha
      POSTGRES_DB: orcha
    # Auth v1 (#271): host-loopback publish by default — the stack is a local tool; LAN
    # exposure is opt-in (`orcha init --expose`, which requires ORCHA_AUTH_MODE=enforce).
    ports: ["{{ bind_host }}{{ db_port }}:5432"]
    volumes:
      - pgdata:/var/lib/postgresql/data
      # initdb runs ONLY the 001 baseline on a fresh volume; the portal's migration runner
      # owns 002+ (mounting the whole dir here would double-apply 002+ — initdb AND runner).
      - ./migrations/001_init.sql:/docker-entrypoint-initdb.d/001_init.sql
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U orcha -d orcha"]
      interval: 3s
      timeout: 3s
      retries: 10
  portal:
    build: ./portal
    environment:
      DATABASE_URL: postgresql://orcha:orcha@db:5432/orcha   # 'db' = service name, inside the network
      MIGRATIONS_DIR: /app/migrations                        # R1: runner applies these on startup
      ORCHA_WAKES_DIR: /app/orcha-wakes                       # SSE: where per-wake stream-json logs are mounted
      # #301: where task-message file attachments are written/served. Backed by a WRITABLE
      # host bind-mount (../.claude/.orcha-attachments) so files live on the project folder
      # (no DB blobs) and survive image rebuilds / `orcha upgrade`.
      ORCHA_ATTACHMENTS_DIR: /app/orcha-attachments
      # #290: Orcha-managed LLM credential (NOT an agent's CLI auth) for the universal llm_util
      # client (onboarding roster builder etc.). Passed through from the host env; empty if unset.
      ORCHA_LLM_API_KEY: ${ORCHA_LLM_API_KEY:-}
      ORCHA_LLM_BASE_URL: ${ORCHA_LLM_BASE_URL:-}
      # #294 Item 1: master key for at-rest encryption of per-container stored LLM keys
      # (secret_box). WITHOUT this in the portal env, PUT .../settings/llm-key 503s and the
      # read path can't unseal. The CLI auto-generates + persists one to .orcha/.env on
      # up/upgrade if the operator hasn't supplied ORCHA_SECRET_KEY (see _ensure_secret_key).
      ORCHA_SECRET_KEY: ${ORCHA_SECRET_KEY:-}
      # ISS-84/#235: advertise THIS project's per-project bridge port to its browser terminal.
      # The host-mapped api_port isn't visible inside the container, so the bridge port is
      # injected explicitly (mirrors how api_port/db_port are chosen per-project). Without this
      # every project's browser dialled the fixed ws://127.0.0.1:8765 = the wrong container.
      ORCHA_TERMINAL_WS_URL: ws://127.0.0.1:{{ bridge_port }}
      # Auth v1 (#271): off | warn | enforce. New `orcha init` projects get enforce;
      # `orcha upgrade` keeps existing stacks on warn (log-only) until the operator flips it.
      ORCHA_AUTH_MODE: {{ auth_mode }}
    ports: ["{{ bind_host }}{{ api_port }}:8000"]
    volumes:
      - ./migrations:/app/migrations:ro   # R1: portal reads migrations to apply pending ones (no wipe)
      # SSE worker-run streaming: the daemon writes each worker's NDJSON log to the host's
      # <project>/.claude/.orcha-wakes/ (one level up from this .orcha/ deploy dir). Mount it
      # read-only so the portal can TAIL it live for GET /api/agents/{aid}/runs/{run_id}/stream.
      - ../.claude/.orcha-wakes:/app/orcha-wakes:ro
      # #301: WRITABLE attachments store. Unlike the read-only mounts above, the portal
      # WRITES uploaded files here (one subdir per task). Lives on the host project folder
      # (<project>/.claude/.orcha-attachments) so attachments are local files — no DB blobs,
      # no new auth — and persist across `orcha upgrade` (image rebuild) like .orcha-wakes.
      # The CLI pre-creates the host dir before `compose up` so Linux doesn't bind-create it
      # as root (which would block user-space writes).
      - ../.claude/.orcha-attachments:/app/orcha-attachments
    depends_on:
      db: { condition: service_healthy }

volumes:
  pgdata:
