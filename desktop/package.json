{
  "name": "orcha-desktop",
  "version": "1.1.0",
  "description": "Orcha Desktop — stack manager for orcha-* Docker stacks (Orcha#237)",
  "main": "./out/main/index.js",
  "author": "Orcha",
  "private": true,
  "scripts": {
    "predev": "node scripts/copy-orcha-templates.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "pretest": "node scripts/copy-orcha-templates.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "copy:templates": "node scripts/copy-orcha-templates.mjs",
    "prebuild": "node scripts/copy-orcha-templates.mjs",
    "predist:mac": "node scripts/copy-orcha-templates.mjs",
    "predist:mac:arm64": "node scripts/copy-orcha-templates.mjs",
    "dist:mac": "electron-vite build && electron-builder --mac --universal",
    "dist:mac:arm64": "electron-vite build && electron-builder --mac --arm64"
  },
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^6.0.0-beta.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
