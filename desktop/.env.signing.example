# Mac code-signing + notarization credentials for `npm run dist:mac`.
#
# Copy this file to `.env.signing.local` (which is gitignored) and fill in the
# real values. NEVER commit the filled-in version — these are secrets that let
# anyone sign software as you.
#
# Then build a signed + notarized app with:
#   ./scripts/dist-mac-signed.sh

# --- Developer ID Application certificate (signing) ---
# Path to the exported .p12 and the password you set when exporting it.
export CSC_LINK="/absolute/path/to/DeveloperID.p12"
export CSC_KEY_PASSWORD="your-p12-export-password"

# --- App Store Connect API key (notarization via notarytool) ---
# The .p8 key file, its Key ID, and your account's Issuer ID, all from
# App Store Connect → Users and Access → Integrations → App Store Connect API.
export APPLE_API_KEY="/absolute/path/to/AuthKey_XXXXXXXXXX.p8"
export APPLE_API_KEY_ID="XXXXXXXXXX"
export APPLE_API_ISSUER="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
